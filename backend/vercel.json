{
  "version": 2,
  "builds": [
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    },
    {
      "src": "pantry_pal/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "30mb",
        "runtime": "python3.11",
        "includeFiles": "staticfiles/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "pantry_pal/wsgi.py"
    },
    { "src": "/admin/(.*)", "dest": "pantry_pal/wsgi.py" },
    { "src": "/(.*)", "dest": "pantry_pal/wsgi.py" }
  ]
}
